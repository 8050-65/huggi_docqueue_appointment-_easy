# ============================================================
# Huggi API — Environment Configuration Template
# ============================================================
# Setup:
#   1. Copy this file to apps/api/.env
#   2. Replace placeholder values with real credentials
#   3. Never commit .env (it is gitignored)
# ============================================================


# ─────────────────────────────────────────────────────────────
# MVP REQUIRED — Backend won't start without these
# ─────────────────────────────────────────────────────────────

# NestJS server port
PORT=3001

# Node environment (development | production | test)
NODE_ENV=development

# PostgreSQL connection string
# IMPORTANT: Huggi Docker PostgreSQL runs on port 5433
# Reason: A Windows-native PostgreSQL 18 service uses port 5432 on dev machines.
#         To avoid conflicts, Huggi's docker-compose.yml maps host port 5433
#         to the container's internal 5432. Do not change this unless you have
#         confirmed port 5432 is free on your machine.
DATABASE_URL="postgresql://huggi:huggi_dev_password@localhost:5433/huggi?schema=public"

# JWT signing secrets — separate secrets for access and refresh tokens
# Generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-64-byte-hex-string-access"
JWT_REFRESH_SECRET="replace-with-64-byte-hex-string-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"


# ─────────────────────────────────────────────────────────────
# MVP FEATURE — Required when Phase 1+ features are wired
# ─────────────────────────────────────────────────────────────

# Firebase Admin SDK — verifies Firebase ID tokens from patient OTP
# Get from Firebase Console → Project Settings → Service Accounts → Generate Key
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# Firebase Cloud Messaging — push notifications to patients
# Same service account as Firebase Admin SDK can be reused
# FCM_PROJECT_ID=""

# MSG91 — transactional SMS (booking confirmed, reminders, queue called)
# DLT template registration is required for India (TRAI compliance, 1–2 week approval)
# MSG91_AUTH_KEY=""
# MSG91_SENDER_ID=""
# MSG91_TEMPLATE_BOOKING_CONFIRMED=""
# MSG91_TEMPLATE_APPOINTMENT_REMINDER=""
# MSG91_TEMPLATE_QUEUE_CALLED=""


# ─────────────────────────────────────────────────────────────
# POST-MVP — Reserved for v1.1+ (do not wire at MVP)
# ─────────────────────────────────────────────────────────────

# Razorpay — payments (UPI, cards, INR invoicing, GST)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# Sentry — server-side error tracking
# SENTRY_DSN=""

# Resend — clinic onboarding emails
# RESEND_API_KEY=""

# PostHog server-side (event ingestion, if needed beyond client SDK)
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://app.posthog.com"

# Cloudflare R2 — object storage (clinic logos, doctor photos, exports)
# Reserved for post-MVP file storage needs
# CLOUDFLARE_R2_BUCKET=""
# CLOUDFLARE_R2_ACCESS_KEY=""
# CLOUDFLARE_R2_SECRET_KEY=""
