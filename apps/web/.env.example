# ============================================================
# Huggi Web — Environment Configuration Template
# ============================================================
# Setup:
#   1. Copy this file to apps/web/.env.local
#   2. Replace placeholder values with real credentials
#   3. Never commit .env.local (it is gitignored)
#
# Next.js convention:
#   - NEXT_PUBLIC_* variables are exposed to the browser bundle
#   - Non-prefixed variables stay server-side only (in API routes)
# ============================================================


# ─────────────────────────────────────────────────────────────
# MVP REQUIRED — Web app won't function without these
# ─────────────────────────────────────────────────────────────

# Public base URL of the Huggi API (NestJS backend)
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Public base URL of the web app itself
# Used for OAuth callbacks, shareable booking links, email/SMS link generation
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# ─────────────────────────────────────────────────────────────
# MVP FEATURE — Required when Phase 1+ features are wired
# ─────────────────────────────────────────────────────────────

# Firebase client SDK — patient phone OTP flow (browser-side)
# Get from Firebase Console → Project Settings → Your apps → Web app config
# NEXT_PUBLIC_FIREBASE_API_KEY=""
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
# NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Cloud Messaging — web push notification setup
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=""


# ─────────────────────────────────────────────────────────────
# POST-MVP — Reserved for v1.1+ (do not wire at MVP)
# ─────────────────────────────────────────────────────────────

# Razorpay client checkout (post-MVP — v1.1)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# PostHog product analytics (client SDK)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Sentry client-side error tracking
# NEXT_PUBLIC_SENTRY_DSN=""
