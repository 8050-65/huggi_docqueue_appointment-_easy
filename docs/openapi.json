":{"type":"string","example":"12, MG Road, Pune, Maharashtra 411001","minLength":5},"phone":{"type":"string","example":"9876543210","minLength":10,"description":"10-digit clinic phone number"}},"required":["name","address","phone"]},"UpdateClinicDto":{"type":"object","properties":{"name":{"type":"string","example":"Sunrise Super Clinic"},"address":{"type":"string","example":"45, FC Road, Pune, Maharashtra 411004"},"phone":{"type":"string","example":"9876543211"}}},"CreateUserDto":{"type":"object","properties":{"email":{"type":"string","example":"nurse.priya@clinic.com"},"password":{"type":"string","example":"secret123","minLength":8},"name":{"type":"string","example":"Priya Sharma","minLength":2},"phone":{"type":"string","example":"9876500001"},"clinicId":{"type":"string","description":"UUID of the clinic to assign this staff member to"},"role":{"type":"string","example":"NURSE","description":"Staff role: CLINIC_ADMIN | RECEPTIONIST | NURSE | DOCTOR | CARE_TAKER | SECURITY | BILLING_STAFF"}},"required":["email","password","name","clinicId","role"]},"UpdateUserDto":{"type":"object","properties":{"email":{"type":"string","example":"priya.new@clinic.com"},"name":{"type":"string","example":"Priya Sharma Gupta","minLength":2},"phone":{"type":"string","example":"9876500002"}}},"CreateDoctorDto":{"type":"object","properties":{"userId":{"type":"string","description":"UUID of the existing User account for this doctor"},"clinicId":{"type":"string","description":"UUID of the clinic this doctor belongs to"},"specialization":{"type":"string","example":"Cardiology","default":"General"},"consultationDuration":{"type":"number","example":30,"minimum":15,"description":"Slot duration in minutes"}},"required":["userId","clinicId"]},"UpdateDoctorDto":{"type":"object","properties":{"specialization":{"type":"string","example":"Neurology"},"consultationDuration":{"type":"number","example":20,"minimum":15},"isAvailable":{"type":"boolean","example":true,"description":"Whether the doctor is a